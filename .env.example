# ============================================================
#  Spark SRE Agent — Environment Variables
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ============================================================

# ── Anthropic / Claude ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-5

# ── Email / SMTP ─────────────────────────────────────────────
# Gmail example: use an App Password (not your real password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASSWORD=your-app-password

ALERT_SENDER=spark-sre-agent@yourcompany.com
ALERT_EMAIL=data-engineering@yourcompany.com,sre-oncall@yourcompany.com

# ── Spark ────────────────────────────────────────────────────
SPARK_MASTER=local[*]

# ── Agent behaviour ──────────────────────────────────────────
# How often (seconds) to poll log directory in --watch mode
WATCH_INTERVAL=30

# ── Airflow (optional, for callback integration) ─────────────
AIRFLOW_LOG_BASE_PATH=/opt/airflow/logs
